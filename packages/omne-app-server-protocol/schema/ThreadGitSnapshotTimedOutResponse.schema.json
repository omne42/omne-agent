{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ThreadGitSnapshotTimedOutResponse",
  "type": "object",
  "required": [
    "process_id",
    "stderr_path",
    "stdout_path",
    "thread_id",
    "timed_out",
    "wait_seconds"
  ],
  "properties": {
    "process_id": {
      "type": "string",
      "format": "uuid"
    },
    "stderr_path": {
      "type": "string"
    },
    "stdout_path": {
      "type": "string"
    },
    "thread_id": {
      "type": "string",
      "format": "uuid"
    },
    "timed_out": {
      "type": "boolean"
    },
    "wait_seconds": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    }
  }
}