{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ThreadCheckpointRestoreDeniedResponse",
  "type": "object",
  "required": [
    "checkpoint_id",
    "denied",
    "thread_id"
  ],
  "properties": {
    "available": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "checkpoint_id": {
      "type": "string",
      "format": "uuid"
    },
    "decision": {
      "default": null,
      "anyOf": [
        {
          "$ref": "#/definitions/ThreadCheckpointDecision"
        },
        {
          "type": "null"
        }
      ]
    },
    "denied": {
      "type": "boolean"
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "load_error": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "mode": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "sandbox_policy": {
      "default": null,
      "anyOf": [
        {
          "$ref": "#/definitions/WriteScope"
        },
        {
          "type": "null"
        }
      ]
    },
    "sandbox_writable_roots": {
      "default": null,
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "thread_id": {
      "type": "string",
      "format": "uuid"
    }
  },
  "definitions": {
    "ThreadCheckpointDecision": {
      "type": "string",
      "enum": [
        "allow",
        "prompt",
        "deny"
      ]
    },
    "WriteScope": {
      "type": "string",
      "enum": [
        "read_only",
        "workspace_write",
        "full_access"
      ]
    }
  }
}