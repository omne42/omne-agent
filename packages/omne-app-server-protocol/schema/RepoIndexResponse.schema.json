{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RepoIndexResponse",
  "type": "object",
  "required": [
    "artifact_id",
    "content_path",
    "created",
    "files_scanned",
    "metadata",
    "metadata_path",
    "paths_listed",
    "root",
    "size_bytes",
    "tool_id",
    "truncated"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "format": "uuid"
    },
    "content_path": {
      "type": "string"
    },
    "created": {
      "type": "boolean"
    },
    "files_scanned": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "metadata": {
      "$ref": "#/definitions/ArtifactMetadata"
    },
    "metadata_path": {
      "type": "string"
    },
    "paths_listed": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "root": {
      "type": "string"
    },
    "size_bytes": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "tool_id": {
      "type": "string",
      "format": "uuid"
    },
    "truncated": {
      "type": "boolean"
    }
  },
  "definitions": {
    "ArtifactMetadata": {
      "type": "object",
      "required": [
        "artifact_id",
        "artifact_type",
        "content_path",
        "created_at",
        "size_bytes",
        "summary",
        "updated_at",
        "version"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "format": "uuid"
        },
        "artifact_type": {
          "type": "string"
        },
        "content_path": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "preview": {
          "anyOf": [
            {
              "$ref": "#/definitions/ArtifactPreview"
            },
            {
              "type": "null"
            }
          ]
        },
        "provenance": {
          "anyOf": [
            {
              "$ref": "#/definitions/ArtifactProvenance"
            },
            {
              "type": "null"
            }
          ]
        },
        "size_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "summary": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "ArtifactPreview": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "$ref": "#/definitions/ArtifactPreviewKind"
        },
        "language": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ArtifactPreviewKind": {
      "type": "string",
      "enum": [
        "markdown",
        "diff_unified",
        "patch_unified",
        "code",
        "html",
        "log"
      ]
    },
    "ArtifactProvenance": {
      "type": "object",
      "required": [
        "thread_id"
      ],
      "properties": {
        "process_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "thread_id": {
          "type": "string",
          "format": "uuid"
        },
        "tool_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "turn_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        }
      }
    }
  }
}