{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArtifactAllowedToolsDeniedResponse",
  "type": "object",
  "required": [
    "tool",
    "tool_id"
  ],
  "properties": {
    "allowed_tools": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "denied": {
      "default": false,
      "type": "boolean"
    },
    "tool": {
      "type": "string"
    },
    "tool_id": {
      "type": "string",
      "format": "uuid"
    }
  }
}