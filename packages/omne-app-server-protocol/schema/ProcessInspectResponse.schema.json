{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProcessInspectResponse",
  "type": "object",
  "required": [
    "process",
    "stderr_tail",
    "stdout_tail",
    "tool_id"
  ],
  "properties": {
    "process": {
      "$ref": "#/definitions/ProcessInfo"
    },
    "stderr_tail": {
      "type": "string"
    },
    "stdout_tail": {
      "type": "string"
    },
    "tool_id": {
      "type": "string",
      "format": "uuid"
    }
  },
  "definitions": {
    "ProcessInfo": {
      "type": "object",
      "required": [
        "argv",
        "cwd",
        "last_update_at",
        "process_id",
        "started_at",
        "status",
        "stderr_path",
        "stdout_path",
        "thread_id"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string"
        },
        "exit_code": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "last_update_at": {
          "type": "string"
        },
        "os_pid": {
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "process_id": {
          "type": "string",
          "format": "uuid"
        },
        "started_at": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/ProcessStatus"
        },
        "stderr_path": {
          "type": "string"
        },
        "stdout_path": {
          "type": "string"
        },
        "thread_id": {
          "type": "string",
          "format": "uuid"
        },
        "turn_id": {
          "default": null,
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        }
      }
    },
    "ProcessStatus": {
      "type": "string",
      "enum": [
        "running",
        "exited",
        "abandoned"
      ]
    }
  }
}