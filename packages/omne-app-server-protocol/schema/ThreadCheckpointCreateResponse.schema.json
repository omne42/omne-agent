{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ThreadCheckpointCreateResponse",
  "type": "object",
  "required": [
    "checkpoint_dir",
    "checkpoint_id",
    "created_at",
    "excluded",
    "manifest_path",
    "size_limits",
    "snapshot_ref",
    "stats",
    "thread_id"
  ],
  "properties": {
    "checkpoint_dir": {
      "type": "string"
    },
    "checkpoint_id": {
      "type": "string",
      "format": "uuid"
    },
    "created_at": {
      "type": "string"
    },
    "excluded": {
      "$ref": "#/definitions/ThreadCheckpointExcluded"
    },
    "label": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "manifest_path": {
      "type": "string"
    },
    "size_limits": {
      "$ref": "#/definitions/ThreadCheckpointSizeLimits"
    },
    "snapshot_ref": {
      "type": "string"
    },
    "stats": {
      "$ref": "#/definitions/ThreadCheckpointStats"
    },
    "thread_id": {
      "type": "string",
      "format": "uuid"
    }
  },
  "definitions": {
    "ThreadCheckpointExcluded": {
      "type": "object",
      "required": [
        "oversize_count",
        "secret_count",
        "symlink_count"
      ],
      "properties": {
        "oversize_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "secret_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "symlink_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "ThreadCheckpointSizeLimits": {
      "type": "object",
      "required": [
        "max_file_bytes",
        "max_total_bytes"
      ],
      "properties": {
        "max_file_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "max_total_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "ThreadCheckpointStats": {
      "type": "object",
      "required": [
        "file_count",
        "total_bytes"
      ],
      "properties": {
        "file_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "total_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    }
  }
}