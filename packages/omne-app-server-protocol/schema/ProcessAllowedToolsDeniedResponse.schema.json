{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProcessAllowedToolsDeniedResponse",
  "type": "object",
  "required": [
    "allowed_tools",
    "denied",
    "tool",
    "tool_id"
  ],
  "properties": {
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "denied": {
      "type": "boolean"
    },
    "error_code": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "tool": {
      "type": "string"
    },
    "tool_id": {
      "type": "string",
      "format": "uuid"
    }
  }
}