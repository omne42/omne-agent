{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ThreadUnpauseResponse",
  "type": "object",
  "required": [
    "already_unpaused",
    "paused",
    "thread_id"
  ],
  "properties": {
    "already_unpaused": {
      "type": "boolean"
    },
    "paused": {
      "type": "boolean"
    },
    "thread_id": {
      "type": "string",
      "format": "uuid"
    }
  }
}