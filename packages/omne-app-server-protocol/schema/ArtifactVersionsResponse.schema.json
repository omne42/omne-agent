{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArtifactVersionsResponse",
  "type": "object",
  "required": [
    "artifact_id",
    "latest_version",
    "tool_id"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "format": "uuid"
    },
    "history_versions": {
      "default": [],
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint32",
        "minimum": 0.0
      }
    },
    "latest_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "tool_id": {
      "type": "string",
      "format": "uuid"
    },
    "versions": {
      "default": [],
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint32",
        "minimum": 0.0
      }
    }
  }
}