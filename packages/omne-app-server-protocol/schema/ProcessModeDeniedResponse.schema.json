{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProcessModeDeniedResponse",
  "type": "object",
  "required": [
    "decision",
    "decision_source",
    "denied",
    "mode",
    "thread_id",
    "tool_id",
    "tool_override_hit"
  ],
  "properties": {
    "decision": {
      "$ref": "#/definitions/ProcessModeDecision"
    },
    "decision_source": {
      "type": "string"
    },
    "denied": {
      "type": "boolean"
    },
    "error_code": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "mode": {
      "type": "string"
    },
    "structured_error": {
      "default": null,
      "anyOf": [
        {
          "$ref": "#/definitions/StructuredTextData"
        },
        {
          "type": "null"
        }
      ]
    },
    "thread_id": {
      "type": "string",
      "format": "uuid"
    },
    "tool_id": {
      "type": "string",
      "format": "uuid"
    },
    "tool_override_hit": {
      "type": "boolean"
    }
  },
  "definitions": {
    "CatalogArgData": {
      "type": "object",
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "value": {
          "$ref": "#/definitions/CatalogArgValueData"
        }
      }
    },
    "CatalogArgValueData": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "text"
              ]
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "bool"
              ]
            },
            "value": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "signed"
              ]
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "unsigned"
              ]
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "nested_text"
              ]
            },
            "value": {
              "$ref": "#/definitions/StructuredTextData"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "unsupported"
              ]
            }
          }
        }
      ]
    },
    "ProcessModeDecision": {
      "type": "string",
      "enum": [
        "allow",
        "prompt",
        "deny"
      ]
    },
    "StructuredTextData": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "args",
            "code",
            "kind"
          ],
          "properties": {
            "args": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/CatalogArgData"
              }
            },
            "code": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "catalog"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "text"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "freeform"
              ]
            },
            "text": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}