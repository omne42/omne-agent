{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "McpSandboxPolicyDeniedResponse",
  "type": "object",
  "required": [
    "sandbox_policy",
    "tool_id"
  ],
  "properties": {
    "denied": {
      "default": false,
      "type": "boolean"
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "sandbox_policy": {
      "$ref": "#/definitions/WriteScope"
    },
    "tool_id": {
      "type": "string",
      "format": "uuid"
    }
  },
  "definitions": {
    "WriteScope": {
      "type": "string",
      "enum": [
        "read_only",
        "workspace_write",
        "full_access"
      ]
    }
  }
}