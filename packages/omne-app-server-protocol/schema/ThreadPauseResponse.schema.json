{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ThreadPauseResponse",
  "type": "object",
  "required": [
    "already_paused",
    "paused",
    "thread_id"
  ],
  "properties": {
    "already_paused": {
      "type": "boolean"
    },
    "interrupted_turn_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "paused": {
      "type": "boolean"
    },
    "thread_id": {
      "type": "string",
      "format": "uuid"
    }
  }
}