{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JsonRpcRequest",
  "type": "object",
  "required": [
    "id",
    "method"
  ],
  "properties": {
    "id": {
      "$ref": "#/definitions/RequestId"
    },
    "jsonrpc": {
      "type": [
        "string",
        "null"
      ]
    },
    "method": {
      "type": "string"
    },
    "params": true
  },
  "definitions": {
    "RequestId": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer",
          "format": "int64"
        }
      ]
    }
  }
}