{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RepoUnknownModeDeniedResponse",
  "type": "object",
  "required": [
    "available",
    "decision",
    "mode",
    "tool_id"
  ],
  "properties": {
    "available": {
      "type": "string"
    },
    "decision": {
      "$ref": "#/definitions/RepoModeDecision"
    },
    "denied": {
      "default": false,
      "type": "boolean"
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "load_error": {
      "type": [
        "string",
        "null"
      ]
    },
    "mode": {
      "type": "string"
    },
    "tool_id": {
      "type": "string",
      "format": "uuid"
    }
  },
  "definitions": {
    "RepoModeDecision": {
      "type": "string",
      "enum": [
        "allow",
        "prompt",
        "deny"
      ]
    }
  }
}