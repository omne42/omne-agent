{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArtifactListResponse",
  "type": "object",
  "required": [
    "tool_id"
  ],
  "properties": {
    "artifacts": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/ArtifactMetadata"
      }
    },
    "errors": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/ArtifactListError"
      }
    },
    "tool_id": {
      "type": "string",
      "format": "uuid"
    }
  },
  "definitions": {
    "ArtifactListError": {
      "type": "object",
      "required": [
        "error",
        "path"
      ],
      "properties": {
        "error": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "ArtifactMetadata": {
      "type": "object",
      "required": [
        "artifact_id",
        "artifact_type",
        "content_path",
        "created_at",
        "size_bytes",
        "summary",
        "updated_at",
        "version"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "format": "uuid"
        },
        "artifact_type": {
          "type": "string"
        },
        "content_path": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "preview": {
          "anyOf": [
            {
              "$ref": "#/definitions/ArtifactPreview"
            },
            {
              "type": "null"
            }
          ]
        },
        "provenance": {
          "anyOf": [
            {
              "$ref": "#/definitions/ArtifactProvenance"
            },
            {
              "type": "null"
            }
          ]
        },
        "size_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "summary": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "ArtifactPreview": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "$ref": "#/definitions/ArtifactPreviewKind"
        },
        "language": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ArtifactPreviewKind": {
      "type": "string",
      "enum": [
        "markdown",
        "diff_unified",
        "patch_unified",
        "code",
        "html",
        "log"
      ]
    },
    "ArtifactProvenance": {
      "type": "object",
      "required": [
        "thread_id"
      ],
      "properties": {
        "process_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "thread_id": {
          "type": "string",
          "format": "uuid"
        },
        "tool_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "turn_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        }
      }
    }
  }
}