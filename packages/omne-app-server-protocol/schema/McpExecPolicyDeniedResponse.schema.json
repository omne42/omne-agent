{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "McpExecPolicyDeniedResponse",
  "type": "object",
  "required": [
    "decision",
    "matched_rules",
    "tool_id"
  ],
  "properties": {
    "decision": {
      "type": "string"
    },
    "denied": {
      "default": false,
      "type": "boolean"
    },
    "matched_rules": true,
    "tool_id": {
      "type": "string",
      "format": "uuid"
    }
  }
}