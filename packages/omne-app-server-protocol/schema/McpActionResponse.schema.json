{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "McpActionResponse",
  "anyOf": [
    {
      "$ref": "#/definitions/McpActionInlineResponse"
    },
    {
      "$ref": "#/definitions/McpActionArtifactResponse"
    }
  ],
  "definitions": {
    "McpActionArtifactResponse": {
      "type": "object",
      "required": [
        "artifact",
        "bytes",
        "process_id",
        "truncated"
      ],
      "properties": {
        "artifact": true,
        "bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "process_id": {
          "type": "string",
          "format": "uuid"
        },
        "truncated": {
          "type": "boolean"
        }
      }
    },
    "McpActionInlineResponse": {
      "type": "object",
      "required": [
        "process_id",
        "result"
      ],
      "properties": {
        "process_id": {
          "type": "string",
          "format": "uuid"
        },
        "result": true
      }
    }
  }
}