{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProcessExecPolicyDeniedResponse",
  "type": "object",
  "required": [
    "decision",
    "denied",
    "matched_rules",
    "tool_id"
  ],
  "properties": {
    "decision": {
      "$ref": "#/definitions/ExecPolicyDecision"
    },
    "denied": {
      "type": "boolean"
    },
    "error_code": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "justification": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "matched_rules": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ExecPolicyRuleMatch"
      }
    },
    "structured_error": {
      "default": null,
      "anyOf": [
        {
          "$ref": "#/definitions/StructuredTextData"
        },
        {
          "type": "null"
        }
      ]
    },
    "tool_id": {
      "type": "string",
      "format": "uuid"
    }
  },
  "definitions": {
    "CatalogArgData": {
      "type": "object",
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "value": {
          "$ref": "#/definitions/CatalogArgValueData"
        }
      }
    },
    "CatalogArgValueData": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "text"
              ]
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "bool"
              ]
            },
            "value": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "signed"
              ]
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "unsigned"
              ]
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "nested_text"
              ]
            },
            "value": {
              "$ref": "#/definitions/StructuredTextData"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "unsupported"
              ]
            }
          }
        }
      ]
    },
    "ExecPolicyDecision": {
      "type": "string",
      "enum": [
        "allow",
        "prompt",
        "prompt_strict",
        "forbidden"
      ]
    },
    "ExecPolicyRuleMatch": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "prefixRuleMatch"
          ],
          "properties": {
            "prefixRuleMatch": {
              "type": "object",
              "required": [
                "decision",
                "matchedPrefix"
              ],
              "properties": {
                "decision": {
                  "$ref": "#/definitions/ExecPolicyDecision"
                },
                "justification": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "matchedPrefix": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "heuristicsRuleMatch"
          ],
          "properties": {
            "heuristicsRuleMatch": {
              "type": "object",
              "required": [
                "command",
                "decision"
              ],
              "properties": {
                "command": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "decision": {
                  "$ref": "#/definitions/ExecPolicyDecision"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "StructuredTextData": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "args",
            "code",
            "kind"
          ],
          "properties": {
            "args": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/CatalogArgData"
              }
            },
            "code": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "catalog"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "text"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "freeform"
              ]
            },
            "text": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}