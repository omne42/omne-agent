{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProcessStartResponse",
  "type": "object",
  "required": [
    "effective_env_summary",
    "process_id",
    "stderr_path",
    "stdout_path"
  ],
  "properties": {
    "effective_env_summary": true,
    "process_id": {
      "type": "string",
      "format": "uuid"
    },
    "stderr_path": {
      "type": "string"
    },
    "stdout_path": {
      "type": "string"
    },
    "timeout_ms": {
      "default": null,
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0.0
    }
  }
}