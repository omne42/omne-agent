{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ThreadStartResponse",
  "type": "object",
  "required": [
    "auto_hook",
    "last_seq",
    "log_path",
    "thread_id"
  ],
  "properties": {
    "auto_hook": {
      "$ref": "#/definitions/ThreadAutoHookResponse"
    },
    "last_seq": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "log_path": {
      "type": "string"
    },
    "thread_id": {
      "type": "string",
      "format": "uuid"
    }
  },
  "definitions": {
    "CatalogArgData": {
      "type": "object",
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "value": {
          "$ref": "#/definitions/CatalogArgValueData"
        }
      }
    },
    "CatalogArgValueData": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "text"
              ]
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "bool"
              ]
            },
            "value": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "signed"
              ]
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "unsigned"
              ]
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "nested_text"
              ]
            },
            "value": {
              "$ref": "#/definitions/StructuredTextData"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "unsupported"
              ]
            }
          }
        }
      ]
    },
    "ExecPolicyDecision": {
      "type": "string",
      "enum": [
        "allow",
        "prompt",
        "prompt_strict",
        "forbidden"
      ]
    },
    "ExecPolicyRuleMatch": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "prefixRuleMatch"
          ],
          "properties": {
            "prefixRuleMatch": {
              "type": "object",
              "required": [
                "decision",
                "matchedPrefix"
              ],
              "properties": {
                "decision": {
                  "$ref": "#/definitions/ExecPolicyDecision"
                },
                "justification": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "matchedPrefix": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "heuristicsRuleMatch"
          ],
          "properties": {
            "heuristicsRuleMatch": {
              "type": "object",
              "required": [
                "command",
                "decision"
              ],
              "properties": {
                "command": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "decision": {
                  "$ref": "#/definitions/ExecPolicyDecision"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "ProcessAllowedToolsDeniedResponse": {
      "type": "object",
      "required": [
        "allowed_tools",
        "denied",
        "tool",
        "tool_id"
      ],
      "properties": {
        "allowed_tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "denied": {
          "type": "boolean"
        },
        "error_code": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "structured_error": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/StructuredTextData"
            },
            {
              "type": "null"
            }
          ]
        },
        "tool": {
          "type": "string"
        },
        "tool_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "ProcessDeniedResponse": {
      "type": "object",
      "required": [
        "denied",
        "thread_id",
        "tool_id"
      ],
      "properties": {
        "denied": {
          "type": "boolean"
        },
        "error_code": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "remembered": {
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "structured_error": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/StructuredTextData"
            },
            {
              "type": "null"
            }
          ]
        },
        "thread_id": {
          "type": "string",
          "format": "uuid"
        },
        "tool_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "ProcessExecPolicyDeniedResponse": {
      "type": "object",
      "required": [
        "decision",
        "denied",
        "matched_rules",
        "tool_id"
      ],
      "properties": {
        "decision": {
          "$ref": "#/definitions/ExecPolicyDecision"
        },
        "denied": {
          "type": "boolean"
        },
        "error_code": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "justification": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "matched_rules": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExecPolicyRuleMatch"
          }
        },
        "structured_error": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/StructuredTextData"
            },
            {
              "type": "null"
            }
          ]
        },
        "tool_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "ProcessExecPolicyLoadDeniedResponse": {
      "type": "object",
      "required": [
        "denied",
        "details",
        "error",
        "mode",
        "tool_id"
      ],
      "properties": {
        "denied": {
          "type": "boolean"
        },
        "details": {
          "type": "string"
        },
        "error": {
          "type": "string"
        },
        "error_code": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "type": "string"
        },
        "structured_error": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/StructuredTextData"
            },
            {
              "type": "null"
            }
          ]
        },
        "tool_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "ProcessModeDecision": {
      "type": "string",
      "enum": [
        "allow",
        "prompt",
        "deny"
      ]
    },
    "ProcessModeDeniedResponse": {
      "type": "object",
      "required": [
        "decision",
        "decision_source",
        "denied",
        "mode",
        "thread_id",
        "tool_id",
        "tool_override_hit"
      ],
      "properties": {
        "decision": {
          "$ref": "#/definitions/ProcessModeDecision"
        },
        "decision_source": {
          "type": "string"
        },
        "denied": {
          "type": "boolean"
        },
        "error_code": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "type": "string"
        },
        "structured_error": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/StructuredTextData"
            },
            {
              "type": "null"
            }
          ]
        },
        "thread_id": {
          "type": "string",
          "format": "uuid"
        },
        "tool_id": {
          "type": "string",
          "format": "uuid"
        },
        "tool_override_hit": {
          "type": "boolean"
        }
      }
    },
    "ProcessSandboxNetworkDeniedResponse": {
      "type": "object",
      "required": [
        "denied",
        "sandbox_network_access",
        "tool_id"
      ],
      "properties": {
        "denied": {
          "type": "boolean"
        },
        "error_code": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "sandbox_network_access": {
          "$ref": "#/definitions/SandboxNetworkAccess"
        },
        "structured_error": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/StructuredTextData"
            },
            {
              "type": "null"
            }
          ]
        },
        "tool_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "ProcessSandboxPolicyDeniedResponse": {
      "type": "object",
      "required": [
        "denied",
        "sandbox_policy",
        "tool_id"
      ],
      "properties": {
        "denied": {
          "type": "boolean"
        },
        "error_code": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "sandbox_policy": {
          "$ref": "#/definitions/WriteScope"
        },
        "structured_error": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/StructuredTextData"
            },
            {
              "type": "null"
            }
          ]
        },
        "tool_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "ProcessUnknownModeDeniedResponse": {
      "type": "object",
      "required": [
        "available",
        "decision",
        "denied",
        "mode",
        "thread_id",
        "tool_id"
      ],
      "properties": {
        "available": {
          "type": "string"
        },
        "decision": {
          "$ref": "#/definitions/ProcessModeDecision"
        },
        "denied": {
          "type": "boolean"
        },
        "error_code": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "load_error": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "type": "string"
        },
        "structured_error": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/StructuredTextData"
            },
            {
              "type": "null"
            }
          ]
        },
        "thread_id": {
          "type": "string",
          "format": "uuid"
        },
        "tool_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "SandboxNetworkAccess": {
      "type": "string",
      "enum": [
        "deny",
        "allow"
      ]
    },
    "StructuredTextData": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "args",
            "code",
            "kind"
          ],
          "properties": {
            "args": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/CatalogArgData"
              }
            },
            "code": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "catalog"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "text"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "freeform"
              ]
            },
            "text": {
              "type": "string"
            }
          }
        }
      ]
    },
    "ThreadAutoHookResponse": {
      "anyOf": [
        {
          "$ref": "#/definitions/ThreadHookRunNeedsApprovalResponse"
        },
        {
          "$ref": "#/definitions/ThreadHookRunDeniedResponse"
        },
        {
          "$ref": "#/definitions/ThreadHookRunResponse"
        },
        {
          "$ref": "#/definitions/ThreadHookRunErrorResponse"
        }
      ]
    },
    "ThreadHookRunDeniedResponse": {
      "type": "object",
      "required": [
        "denied",
        "detail",
        "hook",
        "thread_id"
      ],
      "properties": {
        "config_path": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "denied": {
          "type": "boolean"
        },
        "detail": {
          "$ref": "#/definitions/ThreadProcessDeniedDetail"
        },
        "error_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "hook": {
          "type": "string"
        },
        "structured_error": {
          "anyOf": [
            {
              "$ref": "#/definitions/StructuredTextData"
            },
            {
              "type": "null"
            }
          ]
        },
        "thread_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "ThreadHookRunErrorResponse": {
      "type": "object",
      "required": [
        "error",
        "hook",
        "ok"
      ],
      "properties": {
        "error": {
          "type": "string"
        },
        "hook": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "structured_error": {
          "anyOf": [
            {
              "$ref": "#/definitions/StructuredTextData"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "ThreadHookRunNeedsApprovalResponse": {
      "type": "object",
      "required": [
        "approval_id",
        "hook",
        "needs_approval",
        "thread_id"
      ],
      "properties": {
        "approval_id": {
          "type": "string",
          "format": "uuid"
        },
        "hook": {
          "type": "string"
        },
        "needs_approval": {
          "type": "boolean"
        },
        "thread_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "ThreadHookRunResponse": {
      "type": "object",
      "required": [
        "hook",
        "ok"
      ],
      "properties": {
        "argv": {
          "default": null,
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "config_path": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "hook": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "process_id": {
          "default": null,
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "reason": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "searched": {
          "default": null,
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "skipped": {
          "default": false,
          "type": "boolean"
        },
        "stderr_path": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "stdout_path": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ThreadProcessDeniedDetail": {
      "anyOf": [
        {
          "$ref": "#/definitions/ProcessAllowedToolsDeniedResponse"
        },
        {
          "$ref": "#/definitions/ProcessModeDeniedResponse"
        },
        {
          "$ref": "#/definitions/ProcessUnknownModeDeniedResponse"
        },
        {
          "$ref": "#/definitions/ProcessSandboxPolicyDeniedResponse"
        },
        {
          "$ref": "#/definitions/ProcessSandboxNetworkDeniedResponse"
        },
        {
          "$ref": "#/definitions/ProcessExecPolicyDeniedResponse"
        },
        {
          "$ref": "#/definitions/ProcessExecPolicyLoadDeniedResponse"
        },
        {
          "$ref": "#/definitions/ProcessDeniedResponse"
        }
      ]
    },
    "WriteScope": {
      "type": "string",
      "enum": [
        "read_only",
        "workspace_write",
        "full_access"
      ]
    }
  }
}