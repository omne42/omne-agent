#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:-}"
if [[ -z "$msg_file" || ! -f "$msg_file" ]]; then
  echo "commit-msg: missing commit message file path" >&2
  exit 1
fi

first_line="$(head -n 1 "$msg_file" | tr -d '\r')"
branch_name="$(git branch --show-current 2>/dev/null || true)"

validate_branch_name() {
  local branch="$1"
  local regex='^(main|master|(feat|fix|docs|refactor|perf|test|chore|build|ci|revert)/.+)$'
  [[ -z "$branch" ]] && return 0
  if [[ ! "$branch" =~ $regex ]]; then
    cat >&2 <<EOF
commit-msg: invalid branch name.

Allowed branch names:
  main
  master
  feat/<name>
  fix/<name>
  docs/<name>
  refactor/<name>
  perf/<name>
  test/<name>
  chore/<name>
  build/<name>
  ci/<name>
  revert/<name>

Got: $branch
EOF
    exit 1
  fi
}

validate_branch_name "$branch_name"

# Allow common autogenerated messages.
case "$first_line" in
  Merge\ *) exit 0 ;;
  Revert\ \"*\") exit 0 ;;
  fixup!\ *) exit 0 ;;
  squash!\ *) exit 0 ;;
esac

types="feat|fix|docs|refactor|perf|test|chore|build|ci|revert"
regex="^(${types})(\\([a-z0-9._-]+\\))?(!)?: .+"

if [[ ! "$first_line" =~ $regex ]]; then
  cat >&2 <<'EOF'
commit-msg: invalid commit message.

Expected Conventional Commits format:
  <type>(<scope>)!: <subject>

Allowed types:
  feat, fix, docs, refactor, perf, test, chore, build, ci, revert

Examples:
  feat(omne): concurrent task workspaces
  fix(git): prevent push race with repo lock
  docs(research): add responses notes
  refactor(core)!: split orchestrator state
EOF
  echo >&2
  echo "Got: $first_line" >&2
  exit 1
fi
